# ============================================================================
# VERIFICATION DASHBOARD - ENVIRONMENT VARIABLES
# File: verification-dashboard/.env
# ============================================================================

# 1. ACCESS_PASSWORD
# Password users enter to unlock the dashboard
# This will be updated by the control panel via webhook
ACCESS_PASSWORD=new_password

# 2. SECRET_KEY
# Used for Flask session encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=Welcome_to_AI_World_2024_Random_Secret_Key

# 3. FLASK_DEBUG
# Set to True for development, False for production
FLASK_DEBUG=True

# 4. ADMIN_SECRET (REQUIRED FOR WEBHOOK!)
# Shared secret between control panel and verification dashboard
# MUST BE THE SAME as in control panel!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=W9-sWWiu7vcuNJaeEmbmcnqPtoYMIXqPtiFrxq3cI30

# ============================================================================
# SETUP INSTRUCTIONS:
# ============================================================================
# 
# Step 1: Generate ADMIN_SECRET
# -------------------------------
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Copy the output (e.g., "Xy12Ab34Cd56...")
# 
# Step 2: Paste the same secret in BOTH .env files:
# - verification-dashboard/.env  (this file)
# - password-control-panel/.env  (control panel)
# 
# Step 3: Save and restart both services
# 
# ============================================================================